# Environment Configuration
# Copy this file to .env and fill in your actual values

# Application
APP_NAME=Universal Chatbot Backend
ENVIRONMENT=development
DEBUG=true

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Crawler Settings
CRAWLER_TIMEOUT=30
CRAWLER_MAX_DEPTH=3
CRAWLER_MAX_PAGES=50
CRAWLER_RETRY_ATTEMPTS=3

# Chunk Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Embedding Settings (HuggingFace local by default)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vector Database (FAISS local by default)
VECTOR_DB_PROVIDER=faiss
CHROMADB_PATH=.chroma_db

# RAG Settings
RAG_TOP_K_CHUNKS=4
RAG_CONFIDENCE_THRESHOLD=0.5

# Note: Copy this file to .env and set your actual API keys there

# OpenAI (optional - for production)
# OPENAI_API_KEY=sk_your_key_here
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# OPENAI_LLM_MODEL=gpt-4

# Google Gemini API (for embedding or LLM)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_EMBEDDING_MODEL=text-embedding-004
# GEMINI_LLM_MODEL=gemini-1.5-flash

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
SECRET_KEY=your-secret-key-change-in-production
DATABASE_URL=sqlite:///./chatbot.db
