# Copy this file to .env and fill in your values.

# ── OpenAI (used for both embeddings and the LLM chat model) ──────────────────
OPENAI_API_KEY=sk-...

# ── ChromaDB settings ─────────────────────────────────────────────────────────
# Where ChromaDB persists its data on disk (relative to the backend/ folder)
CHROMA_PERSIST_DIR=./chroma_db

# Name of the collection inside ChromaDB that stores your website's chunks
CHROMA_COLLECTION_NAME=website_knowledge

# ── RAG settings ──────────────────────────────────────────────────────────────
# Number of chunks retrieved per query
RAG_TOP_K=3

# Embedding model to use (text-embedding-3-small is cost-efficient)
EMBEDDING_MODEL=text-embedding-3-small

# Chat / generation model
CHAT_MODEL=gpt-4o-mini

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── CORS (comma-separated list of allowed origins for the chat widget) ────────
# Use "*" during local development; restrict in production.
ALLOWED_ORIGINS=*
