# Environment Configuration
# DO NOT commit this file to version control

# Application
APP_NAME=Universal Chatbot Backend
ENVIRONMENT=development
DEBUG=true

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Crawler Settings
CRAWLER_TIMEOUT=30
CRAWLER_MAX_DEPTH=3
CRAWLER_MAX_PAGES=50
CRAWLER_RETRY_ATTEMPTS=3

# Chunk Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Embedding Settings
# Options: "huggingface" (free, local), "openai" (paid), "google" (paid)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vector Database (ChromaDB local by default)
VECTOR_DB_PROVIDER=faiss
CHROMADB_PATH=.chroma_db

# RAG Settings
RAG_TOP_K_CHUNKS=4
RAG_CONFIDENCE_THRESHOLD=0.5

# Google Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyBqTbsfRx_eG0axe2khz1XuU6FVMZfLhtA
GEMINI_EMBEDDING_MODEL=models/embedding-001
GEMINI_LLM_MODEL=gemini-1.5-flash

# OpenAI (optional - for production)
# OPENAI_API_KEY=sk_your_key_here
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# OPENAI_LLM_MODEL=gpt-4

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
SECRET_KEY=your-secret-key-change-in-production
DATABASE_URL=sqlite:///./chatbot.db
